<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#A17BE6"> <androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_marginTop="20dp"
    android:layout_marginBottom="25dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="8dp"
    android:layout_gravity="center_horizontal">
    <ImageView
        android:id="@+id/ivDashboardIllustration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:src="@drawable/login_illustration" /> </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Campus Dashboard"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="30dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMap"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="CAMPUS MAP"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#A17BE6"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="30dp"
            app:elevation="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotes"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="20dp"
            android:text="MY NOTES"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#8159C1"
            app:cornerRadius="30dp"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="2dp"
            android:layout_marginBottom="60dp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="LOGOUT"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#FF5252"
        app:cornerRadius="20dp"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:layout_gravity="center_horizontal" />

</LinearLayout>