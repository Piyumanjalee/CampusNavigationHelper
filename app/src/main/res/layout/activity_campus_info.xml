<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Campus Navigation Info"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/dark_surface"
            app:strokeColor="@color/dark_card_border"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Get Directions"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category:"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From:"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinnerFrom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:minHeight="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To:"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinnerTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:minHeight="48dp" />

                <ImageView
                    android:id="@+id/imgBlueprint"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sample_blueprint"
                    android:layout_marginBottom="16dp"
                    android:visibility="visible"
                    android:contentDescription="Map Blueprint" />

                <TextView
                    android:id="@+id/txtRoute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:visibility="gone"
                    android:background="#2E2E3A"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:lineSpacingExtra="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNavigate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Navigate"
                    android:layout_marginBottom="8dp"
                    app:backgroundTint="@color/color_primary"
                    android:textColor="@color/dark_background"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewGoogleMap"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="VIEW GOOGLE MAP"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"
                    android:textColor="@color/color_primary"
                    android:textStyle="bold"
                    app:strokeColor="@color/color_primary"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewFloorPlan"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="View Floor Plan"
                    android:visibility="gone"
                    app:backgroundTint="@color/color_accent"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 1st Card: Main Library -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/dark_surface"
            app:strokeColor="@color/dark_card_border"
            app:strokeWidth="1.5dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Main Library"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location: Next to the Faculty of Science.\nOperating Hours: 8:00 AM - 7:00 PM."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavLibrary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="ADD TO FAVOURITE"
                    android:layout_gravity="end"
                    android:textSize="12sp"
                    app:backgroundTint="@color/color_secondary"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2nd Card: IT Faculty Building -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/dark_surface"
            app:strokeColor="@color/dark_card_border"
            app:strokeWidth="1.5dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. IT Faculty Building"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location: Behind the main auditorium. Follow the second left path from the gate."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavIT"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="ADD TO FAVOURITE"
                    android:layout_gravity="end"
                    android:textSize="12sp"
                    app:backgroundTint="@color/color_secondary"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3rd Card: Student Canteen -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/dark_surface"
            app:strokeColor="@color/dark_card_border"
            app:strokeWidth="1.5dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Student Canteen"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location: Near the playground. Open for Breakfast and Lunch."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavCanteen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="ADD TO FAVOURITE"
                    android:layout_gravity="end"
                    android:textSize="12sp"
                    app:backgroundTint="@color/color_secondary"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4th Card: Faculty of Applied Sciences -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/dark_surface"
            app:strokeColor="@color/dark_card_border"
            app:strokeWidth="1.5dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. Faculty of Applied Sciences"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location: Near the Main Entrance, Mihintale.\nDepartments: Biological &amp; Physical Sciences."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavApplied"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="ADD TO FAVOURITE"
                    android:layout_gravity="end"
                    android:textSize="12sp"
                    app:backgroundTint="@color/color_secondary"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5th Card: Main Library (Alt) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/dark_surface"
            app:strokeColor="@color/dark_card_border"
            app:strokeWidth="1.5dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5. Main Library"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location: Centrally located near Humanities Faculty.\nOpen: Weekdays 8 AM - 6 PM."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFavMainLib"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="ADD TO FAVOURITE"
                    android:layout_gravity="end"
                    android:textSize="12sp"
                    app:backgroundTint="@color/color_secondary"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>